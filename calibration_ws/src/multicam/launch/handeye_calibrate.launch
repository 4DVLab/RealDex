<launch>
  <!-- (start your robot's MoveIt! stack, e.g. include its moveit_planning_execution.launch) -->
  <!-- (start your tracking system's ROS driver) -->


  <include file="$(find azure_kinect_ros_driver)/launch/driver.launch">
    <arg name="overwrite_robot_description" value="false"/>
  </include>

  <include file="$(find easy_handeye)/launch/calibrate.launch">
    <arg name="eye_on_hand" value="false"/>
    <arg name="namespace_prefix" value="cam_to_hand"/>

    <!-- fill in the following parameters according to your robot's published tf frames -->
    <arg name="robot_base_frame" value="base_link"/>
    <arg name="robot_effector_frame" value=""/>

    <!-- fill in the following parameters according to your tracking system's published tf frames -->
    <arg name="tracking_base_frame" value="camera_base"/>
    <arg name="tracking_marker_frame" value="tag0"/>

    <arg name="start_rviz" value="false"/>

    <arg name="move_group" value=""/>
  </include>
</launch>